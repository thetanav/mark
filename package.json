{
  "name": "mark",
  "version": "0.1.0",
  "description": "Minimal markdown editor with vault management",
  "main": "src/main/index.js",
  "scripts": {
    "dev:vite": "vite --strictPort",
    "dev:preload": "tsc --project tsconfig.preload.json --watch",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron src/main/index.js",
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "build:renderer": "vite build --outDir dist/renderer",
    "build:preload": "tsc --project tsconfig.preload.json",
    "build": "npm run build:renderer && npm run build:preload",
    "dist:win": "npm run build && electron-builder --win portable",
    "start": "electron src/main/index.js",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.mark.app",
    "productName": "Mark",
    "asar": true,
    "files": [
      "src/main/index.js",
      "dist/preload/**",
      "dist/renderer/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "Mark-${version}.exe"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/geist-mono": "^5.0.8",
    "@fontsource/geist-sans": "^5.0.8",
    "docx": "^9.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.460.0",
    "markdown-to-jsx": "^7.4.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "uuid": "^11.1.0",
    "vite": "^5.4.11",
    "wait-on": "^9.0.5"
  }
}
